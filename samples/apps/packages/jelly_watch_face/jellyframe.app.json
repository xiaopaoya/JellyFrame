{
  "$schema": "../../../../tools/schemas/jellyframe.app.schema.json",
  "format": "jellyframe.app",
  "formatVersion": 0,
  "id": "org.jellyframe.examples.watch_face",
  "name": "Jelly Watch Face",
  "version": {
    "name": "0.1.0",
    "code": 1
  },
  "entry": "/index.html",
  "runtime": {
    "minJellyFrame": "0.4.0",
    "script": "classic"
  },
  "viewport": {
    "designWidth": 300,
    "designHeight": 300,
    "shape": "round"
  },
  "budgets": {
    "maxResourceBytes": 32768,
    "maxDomNodes": 128,
    "maxCssRules": 128,
    "maxDisplayCommands": 256,
    "maxTimers": 4,
    "maxEventListeners": 8
  },
  "targets": {
    "round-300": {
      "viewport": {
        "width": 300,
        "height": 300,
        "shape": "round"
      },
      "fontProfile": "tiny-plus-symbols",
      "output": "cpp"
    },
    "rect-320x240": {
      "viewport": {
        "width": 320,
        "height": 240,
        "shape": "rect"
      },
      "fontProfile": "tiny-plus-symbols",
      "output": "cpp"
    },
    "rect-172x320": {
      "viewport": {
        "width": 172,
        "height": 320,
        "shape": "rect"
      },
      "fontProfile": "tiny-plus-symbols",
      "output": "cpp"
    }
  }
}
