# JellyFrame deterministic Win32 watch-face capture script.
# Run with:
#   jellyframe_win32_browser.exe --app samples/apps/packages/jelly_watch_face --frame-script samples/apps/packages/jelly_watch_face/capture_watch_face_30fps.jfcapture

output-dir out/watch_face_frames
montage out/watch_face_montage.bmp
frames 30
step-ms 167
start-ms 1000
viewport 300 300
columns 6
gap 6
animation-fps 30
animation-callbacks 4
