# JellyFrame deterministic low-power animation-budget script.
# The page should remain stable and non-crashing with animation callbacks disabled.

output-dir out/motion_lab_low_power_frames
montage out/motion_lab_low_power_montage.bmp
frames 30
step-ms 33
start-ms 1000
viewport 300 300
columns 6
gap 6
animation-fps 0
animation-callbacks 0

event 4 low-power-on
event 8 pointer-move 150 260
event 9 click 150 260
event 20 low-power-off
