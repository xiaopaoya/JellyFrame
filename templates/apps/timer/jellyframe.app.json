{
  "$schema": "https://jellyframe.dev/schemas/jellyframe.app.schema.json",
  "format": "jellyframe.app",
  "formatVersion": 0,
  "id": "org.jellyframe.template.timer",
  "name": "Timer",
  "version": {
    "name": "0.1.0",
    "code": 1
  },
  "entry": "/index.html",
  "runtime": {
    "minJellyFrame": "0.4.0",
    "script": "classic"
  },
  "viewport": {
    "designWidth": 300,
    "designHeight": 300,
    "shape": "round"
  },
  "budgets": {
    "maxResourceBytes": 131072,
    "maxDomNodes": 384,
    "maxCssRules": 192,
    "maxDisplayCommands": 384,
    "maxTimers": 4,
    "maxEventListeners": 24
  },
  "targets": {
    "round-300": {
      "viewport": {
        "width": 300,
        "height": 300,
        "shape": "round"
      },
      "fontProfile": "tiny",
      "output": "cpp"
    }
  }
}
